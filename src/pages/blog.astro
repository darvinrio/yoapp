---
import PageTitle from "../components/PageTitle.astro";
import Layout from "../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const posts: CollectionEntry<"blog">[] = (await getCollection("blog")).sort(
  (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
    b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout>
  <main class="container-max px-4 py-12 font-text">
    <PageTitle title="Writings" backHref="/" />
    <ul class="flex flex-col gap-6">
      {
        posts.map((post) => (
          <li class="border-b border-gray-200 dark:border-zinc-700 pb-6 last:border-0">
            <a href={`/blog/${post.id}`} class="group block">
              <h2 class="font-text text-2xl group-hover:text-teal-500 dark:group-hover:text-teal-400 transition-colors">
                {post.data.title}
              </h2>
              <time
                datetime={post.data.date.toISOString()}
                class="text-sm text-gray-500 dark:text-zinc-400 mt-1 block"
              >
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
              <p class="mt-2 text-gray-700 dark:text-zinc-300">
                {post.data.description}
              </p>
              <div class="mt-3 flex flex-wrap gap-2">
                {post.data.tags.map((tag: string) => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-teal-100 text-teal-700 dark:bg-zinc-700 dark:text-teal-300">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
