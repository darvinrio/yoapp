---
import {
  getCollection,
  getEntry,
  render,
  type CollectionEntry,
} from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
import "../../styles/blog.css";
import PageTitle from "../../components/PageTitle.astro";

export async function getStaticPaths() {
  const posts: CollectionEntry<"blog">[] = await getCollection("blog");
  return posts.map(
    (
      post,
    ): {
      params: { slug: string };
      props: { post: CollectionEntry<"blog"> };
    } => ({
      params: { slug: post.id },
      props: { post },
    }),
  );
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content } = await render(post);
---

<PostLayout>
  <article class="font-text">
    <PageTitle title={post.data.title} backHref="/blog">
      <time
        slot="actions"
        datetime={post.data.date.toISOString()}
        class="text-sm text-gray-500 dark:text-zinc-400 mt-2 block"
      >
        {
          post.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </time>
    </PageTitle>
    <div class="mt-3 flex flex-wrap gap-2">
      {
        post.data.tags.map((tag: string) => (
          <span class="text-xs px-2 py-0.5 rounded-full bg-teal-100 text-teal-700 dark:bg-zinc-700 dark:text-teal-300">
            {tag}
          </span>
        ))
      }
    </div>
    <div class="prose dark:prose-invert max-w-none text-justify break-words">
      <Content />
    </div>
  </article>
</PostLayout>
