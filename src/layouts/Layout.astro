---
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
---

<!doctype html>
<html lang="en" class="dark:bg-zinc-800">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Merriweather:wght@300;400;700;900&display=swap"
      rel="stylesheet"
    />
    <title>yonas</title>
  </head>
  <Analytics />
  <SpeedInsights />
  <body class="text-black dark:text-mauve-200">
    <Navbar />
    <slot />
    <div
      style="position:fixed;inset:0;pointer-events:none;z-index:0;background-image:url('/texture.png');background-repeat:repeat;background-position:center top;background-size:192px;opacity:0.05;"
    >
    </div>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
