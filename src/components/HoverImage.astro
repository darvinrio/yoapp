---
import type { ImageMetadata } from "astro";

interface Props {
  text: string;
  image: ImageMetadata;
  alt?: string;
  width?: number;
  height?: number;
  class?: string;
}

const {
  text,
  image,
  alt = text,
  width = image.width,
  height = image.height,
  class: className = "",
} = Astro.props;
---

<span class={`hover-image-text ${className}`}>
  <span class="text">{text}</span>
  <span class="image-wrap" aria-hidden="true">
    <img
      src={image.src}
      alt={alt}
      width={width}
      height={height}
      loading="lazy"
      decoding="async"
    />
  </span>
</span>

<style>
  .hover-image-text {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .text {
    display: inline-block;
  }

  .image-wrap {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
    white-space: nowrap;
  }

  .image-wrap img {
    height: 100%;
    width: auto;
    display: inline-block;
    object-fit: contain;
  }

  .hover-image-text:hover .text,
  .hover-image-text:focus-within .text {
    opacity: 0;
  }

  .hover-image-text:hover .image-wrap,
  .hover-image-text:focus-within .image-wrap {
    opacity: 1;
  }
</style>
