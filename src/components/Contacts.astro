---
import { contacts } from "../data/contact";
---

<div class="mt-6 flex items-center gap-4">
  {
    contacts.map((contact) => (
      <a
        href={contact.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={contact.name}
        class="hover:text-teal-600 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          {contact.name === "Twitter" && (
            <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 8.8 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z" />
          )}
          {contact.name === "GitHub" && (
            <path d="M15 22v-4a4.2 4.2 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.16-.42-2.28-1.22-3.1.9-.7 1.42-1.76 1.42-2.86 0-2.1-1.7-3.8-3.8-3.8-1.62 0-3.2 1.1-3.8 2.7A10.2 10.2 0 0 0 3.2 5.3c-1.14.77-1.5 2.16-1.5 3.4 0 3.5 3 6.4 6.8 6.4-2.3 1.8-5.26 2.9-8.4 2.9A12.76 12.76 0 0 1 5 17.3c2.4 1.9 5.6 3 9 3s6.6-1.1 9-3z" />
          )}
          {contact.name === "LinkedIn" && (
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
          )}
          {contact.name === "Telegram" && (
            <>
              <path d="M22 2 11 13" />
              <path d="M22 2 15 22 11 13 2 9z" />
            </>
          )}
        </svg>
      </a>
    ))
  }
</div>
