---

<button
  id="dark-toggle"
  aria-label="Toggle dark mode"
  class="p-2 rounded-full bg-white dark:bg-zinc-700 shadow-md text-yellow-500 dark:text-yellow-300 hover:scale-110 transition-transform"
>
  <svg
    id="icon-sun"
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="hidden dark:block text-mauve-200"
    ><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path
      d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path
      d="m17.49 17.49 1.41 1.41"></path><path d="M2 12h2"></path><path
      d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path
      d="m19.07 4.93-1.41 1.41"></path></svg
  >
  <svg
    id="icon-moon"
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="block dark:hidden text-black"
    ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg
  >
</button>

<script>
  const html = document.documentElement;
  const saved = localStorage.getItem("theme");
  if (saved === "dark") html.classList.add("dark");
  else if (saved === "light") html.classList.remove("dark");

  document.getElementById("dark-toggle")?.addEventListener("click", () => {
    const isDark = html.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });
</script>
