---
interface Props {
  title: string;
  backHref?: string;
}

const { title, backHref } = Astro.props;
---

<div class="mt-2">
  <div class="flex items-center justify-between mb-2">
    <h1 class="font-title text-3xl text-black dark:text-mauve-100">
      {title}<span class="text-teal-500 dark:text-teal-400">.</span>
    </h1>
    <slot name="actions" />
  </div>
  {backHref && (
    <a
      href={backHref}
      class="inline-block text-sm text-gray-500 dark:text-zinc-400 hover:text-teal-500 dark:hover:text-teal-400 mt-0 mb-8 transition-colors"
      >← back</a
    >
  )}
  <hr class="border-t border-teal-500 dark:border-teal-400 mb-8" />
  <slot />
</div>
