{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "nous-portal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Nous Portal",
      "options": {
        "baseURL": "https://inference-api.nousresearch.com/v1",
        "apiKey": "{env:NOUS_OPENCODE_API_KEY}",
      },
      "models": {
        "stepfun/step-3.7-flash:free": {
          "name": "Step 3.7 Flash Free",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
      },
    },
  },
}
